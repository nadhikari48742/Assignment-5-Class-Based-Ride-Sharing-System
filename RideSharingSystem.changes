 Transcript show: 'Driver: ', name; cr.    Transcript show: 'Rating: ', rating asString; cr.! !Object << #Rider    slots: { #riderID . #name . #requestedRides };    package: 'RideSharingSystem'!!Rider methodsFor: 'nil' stamp: '2026-07-06T11:12:16.287+03:00'!initialize    super initialize.    requestedRides := OrderedCollection new.! !!Rider methodsFor: 'nil' stamp: '2026-07-06T11:12:30.739+03:00'!requestRide: aRide    requestedRides add: aRide.! !!Rider methodsFor: 'nil' stamp: '2026-07-06T11:12:44.16+03:00'!viewRides    Transcript show: 'Ride History'; cr.    requestedRides do: [ :ride |        Transcript show: ride printString; cr ].! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:15:13.626+03:00'!rideID    ^rideID! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:15:19.807+03:00'!rideID: anID    rideID := anID.! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:15:36.263+03:00'!distance    ^distance! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:15:51.427+03:00'!distance: aDistance    distance := aDistance.! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:16:02.222+03:00'!fare    ^fare! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:16:12.67+03:00'!fare: anAmount    fare := anAmount.! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:16:24.667+03:00'!pickupLocation    ^pickupLocation! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:16:37.623+03:00'!pickupLocation: aLocation    pickupLocation := aLocation.! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:16:49.993+03:00'!dropoffLocation    ^dropoffLocation! !!Ride methodsFor: 'nil' stamp: '2026-07-06T11:17:00.593+03:00'!dropoffLocation: aLocation    dropoffLocation := aLocation.! !!Driver methodsFor: 'nil' stamp: '2026-07-06T11:18:26.722+03:00'!driverID    ^driverID! !!Driver methodsFor: 'nil' stamp: '2026-07-06T11:18:39.749+03:00'!driverID: anID    driverID := anID.! !!Driver methodsFor: 'nil' stamp: '2026-07-06T11:18:52.112+03:00'!name    ^name! !!Driver methodsFor: 'nil' stamp: '2026-07-06T11:19:02.829+03:00'!name: aName    name := aName.! !!Driver methodsFor: 'nil' stamp: '2026-07-06T11:19:13.539+03:00'!rating    ^rating! !!Driver methodsFor: 'nil' stamp: '2026-07-06T11:19:24.52+03:00'!rating: aRating    rating := aRating.! !!Driver methodsFor: 'nil' stamp: '2026-07-06T11:19:36.069+03:00'!assignedRides    ^assignedRides! !!Rider methodsFor: 'nil' stamp: '2026-07-06T11:20:12.534+03:00'!riderID    ^riderID! !!Rider methodsFor: 'nil' stamp: '2026-07-06T11:20:24.159+03:00'!riderID: anID    riderID := anID.! !!Rider methodsFor: 'nil' stamp: '2026-07-06T11:20:34.403+03:00'!name    ^name! !!Rider methodsFor: 'nil' stamp: '2026-07-06T11:20:45.425+03:00'!name: aName    name := aName.! !!Rider methodsFor: 'nil' stamp: '2026-07-06T11:20:55.9+03:00'!requestedRides    ^requestedRides! !